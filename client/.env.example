# Put React env vars in THIS folder (client/), not in server/.env
#
# Copy to .env.local to override (optional). For npm start, .env.development is used.
#
# API origin only — no /api on the end (the app adds /api automatically).
REACT_APP_API_URL=http://localhost:5000
#
# GitHub Pages: set REACT_APP_API_URL to your API origin for a live backend.
# Omit it (or set REACT_APP_DEMO_MODE=true) for offline demo — data in localStorage only.
# See .github/DEPLOY.md
#
# Optional — Google Sign-In (OAuth 2.0 Web client ID; set GOOGLE_CLIENT_ID on the API server too)
# REACT_APP_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
