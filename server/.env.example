# --- This file is for the Node API only (server/). ---
# Do NOT put REACT_APP_* here — those belong in client/.env.development or GitHub Actions variables.
#
# Real-time chat = same server as REST API (Socket.IO on PORT).
# Database name is the path after the host (use your real name, e.g. skillswapdb).
MONGO_URI=mongodb://127.0.0.1:27017/skillswapdb
JWT_SECRET=change-me-to-a-long-random-string
PORT=5000

# Browser origin(s) allowed for CORS + Socket.IO (comma-separated).
# Local dev (React on 3000, API on 5000): http://localhost:3000
# One public link (API serves client/build): https://your-app.onrender.com
CLIENT_ORIGIN=http://localhost:3000

# Optional — Google Sign-In (same value as REACT_APP_GOOGLE_CLIENT_ID in client/.env)
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# After `npm run build` in client/, serve one URL for UI + API + chat:
# SERVE_CLIENT=true
